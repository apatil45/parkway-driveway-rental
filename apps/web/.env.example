# Database
# Dev: Use Supabase (add ?sslmode=require) or local PostgreSQL
# Prod: Set in Vercel/hosting env vars - use Supabase Connection pooling for serverless
# Supabase direct: postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres?sslmode=require
# Local: postgresql://postgres:postgres@localhost:5432/driveway_rental
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/driveway_rental"

# JWT
JWT_SECRET="your-jwt-secret"
JWT_REFRESH_SECRET="your-refresh-secret"

# Google OAuth (optional - add for "Continue with Google")
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Server
PORT=3000
NODE_ENV=development

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLIC_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Geocoding
OPENCAGE_API_KEY=your-opencage-key

# Routing (optional - override OSRM service URL; default: https://router.project-osrm.org)
# OSRM_URL=https://router.project-osrm.org

# Frontend
FRONTEND_URL=http://localhost:5173
REACT_APP_STRIPE_PUBLIC_KEY=pk_test_...
REACT_APP_API_URL=http://localhost:3000

# Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Supabase (for Auth/Storage when used)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Email
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM=your-email@gmail.com
EMAIL_TO=your-email@gmail.com
